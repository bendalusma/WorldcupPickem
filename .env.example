# Copy this file to ".env" and fill in your real values.
# The .env file is git-ignored and never leaves your machine.

# --- Supabase: safe to expose to the browser (the "anon" key is public by design) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Server-side ONLY. Never prefixed with VITE_, so Vite will not ship it to the browser ---
# Used by the fixtures-import and auto-results scripts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FOOTBALL_DATA_TOKEN=your-football-data-org-token

# Admin login (used once by the create-admin script). Server-side only.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=choose-a-strong-password

# Protects the /api/update-results endpoint. Pick any random string (e.g. run:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# in your terminal, then paste the result here and in Vercel env vars).
CRON_SECRET=your-random-secret-here
